# ingestion-worker-v2 environment reference
# For each variable:
# - required: yes | no | conditional
# - default: value used when not set
# - options: accepted values/range

###############################################################################
# Service bootstrap
###############################################################################

# PORT
# required: no
# default: 3020
# options: integer 1..65535
PORT=3020

# SERVICE_NAME
# required: no
# default: ingestion-worker
# options: any non-empty string
SERVICE_NAME=ingestion-worker

# SERVICE_VERSION
# required: no
# default: 2.0.0
# options: any non-empty string
SERVICE_VERSION=2.0.0

# LOG_LEVEL
# required: no
# default: info
# options: fatal | error | warn | info | debug | trace | silent
LOG_LEVEL=info

# LOG_PRETTY
# required: no
# default: false
# options: true | false | 1 | 0 | yes | no
LOG_PRETTY=false

# MAX_CONCURRENT_RUNS
# required: no
# default: 4
# options: integer 1..128
MAX_CONCURRENT_RUNS=4

###############################################################################
# Control-plane authentication
###############################################################################

# CONTROL_AUTH_MODE
# required: no
# default: token
# options: token | jwt
CONTROL_AUTH_MODE=token

# CONTROL_SHARED_TOKEN
# required: conditional (required when CONTROL_AUTH_MODE=token)
# default: none
# options: non-empty string
CONTROL_SHARED_TOKEN=replace-me

# CONTROL_JWT_PUBLIC_KEY
# required: conditional (required when CONTROL_AUTH_MODE=jwt)
# default: none
# options: non-empty PEM public key
# multiline values are allowed; keep escaped newlines in .env files when needed
CONTROL_JWT_PUBLIC_KEY=

###############################################################################
# GCP + Pub/Sub connectivity
###############################################################################

# GCP_PROJECT_ID
# required: yes
# default: none
# options: non-empty GCP project id
GCP_PROJECT_ID=your-gcp-project

# PUBSUB_EVENTS_TOPIC
# required: yes
# default: none
# options: non-empty topic name
PUBSUB_EVENTS_TOPIC=run-events

# PUBSUB_EVENTS_SUBSCRIPTION
# required: no
# default: <SERVICE_NAME>-events-subscription
# options: non-empty subscription name
PUBSUB_EVENTS_SUBSCRIPTION=

# PUBSUB_AUTO_CREATE_SUBSCRIPTION
# required: no
# default: true
# options: true | false | 1 | 0 | yes | no
PUBSUB_AUTO_CREATE_SUBSCRIPTION=true

# ENABLE_PUBSUB_CONSUMER
# required: no
# default: true
# options: true | false | 1 | 0 | yes | no
ENABLE_PUBSUB_CONSUMER=true

# Downloadable JSON storage routing is run-scoped.
# It is provided by control-service in StartRun.outputSinks[].delivery.
# No bootstrap OUTPUTS_* env vars are required in v2.1.

###############################################################################
# MongoDB
###############################################################################

# MONGODB_URI
# required: yes
# default: none
# options: valid MongoDB connection string
MONGODB_URI=mongodb://localhost:27017

###############################################################################
# Parser backend selection
###############################################################################

# INGESTION_PARSER_BACKEND
# required: no
# default: gemini
# options: gemini | fixture
INGESTION_PARSER_BACKEND=fixture

# GEMINI_API_KEY
# required: conditional (required when INGESTION_PARSER_BACKEND=gemini)
# default: none
# options: non-empty API key string
GEMINI_API_KEY=

# LANGSMITH_API_KEY
# required: conditional (required when INGESTION_PARSER_BACKEND=gemini)
# default: none
# options: non-empty API key string
LANGSMITH_API_KEY=

###############################################################################
# LLM/parser tuning
###############################################################################

# LLM_EXTRACTOR_PROMPT_NAME
# required: no
# default: jobcompass-job-ad-structured-extractor
# options: any non-empty string
LLM_EXTRACTOR_PROMPT_NAME=jobcompass-job-ad-structured-extractor

# LLM_CLEANER_PROMPT_NAME
# required: no
# default: jobcompass-job-ad-text-cleaner
# options: any non-empty string
LLM_CLEANER_PROMPT_NAME=jobcompass-job-ad-text-cleaner

# GEMINI_MODEL
# required: no
# default: gemini-3-flash-preview
# options: any supported Gemini model name
GEMINI_MODEL=gemini-3-flash-preview

# GEMINI_TEMPERATURE
# required: no
# default: 0
# options: number in range 0..1
GEMINI_TEMPERATURE=0

# GEMINI_THINKING_LEVEL
# required: no
# default: LOW
# options: THINKING_LEVEL_UNSPECIFIED | LOW | MEDIUM | HIGH
GEMINI_THINKING_LEVEL=LOW

# GEMINI_INPUT_PRICE_USD_PER_1M_TOKENS
# required: no
# default: 0.5
# options: non-negative number
GEMINI_INPUT_PRICE_USD_PER_1M_TOKENS=0.5

# GEMINI_OUTPUT_PRICE_USD_PER_1M_TOKENS
# required: no
# default: 3
# options: non-negative number
GEMINI_OUTPUT_PRICE_USD_PER_1M_TOKENS=3

# DETAIL_PAGE_MIN_RELEVANT_TEXT_CHARS
# required: no
# default: 700
# options: integer 100..300000
DETAIL_PAGE_MIN_RELEVANT_TEXT_CHARS=700

# LOG_TEXT_TRANSFORM_CONTENT
# required: no
# default: false
# options: true | false | 1 | 0 | yes | no
LOG_TEXT_TRANSFORM_CONTENT=false

# LOG_TEXT_TRANSFORM_PREVIEW_CHARS
# required: no
# default: 1200
# options: integer 120..20000
LOG_TEXT_TRANSFORM_PREVIEW_CHARS=1200

# PARSER_VERSION
# required: no
# default: ingestion-worker-v2-v1-model
# options: any non-empty string
PARSER_VERSION=ingestion-worker-v2-v1-model
