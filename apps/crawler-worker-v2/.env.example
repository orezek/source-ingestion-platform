# ======================================
# Service Bootstrap
# ======================================
# TCP port for the Fastify server.
# Required: optional
# Default: 3010
PORT=3010

# Worker process identity.
# Required: optional
# Default: crawler-worker
SERVICE_NAME=crawler-worker

# Worker version string for logs and diagnostics.
# Required: optional
# Default: 2.0.0
SERVICE_VERSION=2.0.0

# Pino log level.
# Required: optional
# Default: info
# Options: fatal, error, warn, info, debug, trace, silent
LOG_LEVEL=info

# Pretty-print logs in interactive local runs.
# Required: optional
# Default: false
# Options: true, false
LOG_PRETTY=true

# Maximum number of crawl runs the worker executes concurrently.
# Required: optional
# Default: 2
MAX_CONCURRENT_RUNS=2

# ======================================
# Control Plane Auth
# ======================================
# Control-plane auth mode.
# Required: optional
# Default: token
# Options: token, jwt
CONTROL_AUTH_MODE=token

# Required when CONTROL_AUTH_MODE=token.
# Required: conditional
# Default: none
CONTROL_SHARED_TOKEN=dev-control-token

# Required when CONTROL_AUTH_MODE=jwt.
# Required: conditional
# Default: none
CONTROL_JWT_PUBLIC_KEY=

# ======================================
# GCP and Pub/Sub
# ======================================
# GCP project used for Pub/Sub publication and GCS artifact writes.
# Required: yes
# Default: none
GCP_PROJECT_ID=your-gcp-project

# Pub/Sub topic that receives runtime events.
# Required: yes
# Default: none
PUBSUB_EVENTS_TOPIC=run-events

# Artifact sink and persistence target routing are not configured in bootstrap env.
# They are injected by control-service in the v2 StartRun payload.
# - artifactSink (gcs/local_filesystem)
# - persistenceTargets.mongodbUri + persistenceTargets.dbName

# ======================================
# Mongo Sink Guardrails (Optional)
# ======================================
# These tune run-scoped Mongo sink client reuse behavior.
# Mongo sink pool and lifecycle guardrails used for run-scoped StartRun.persistenceTargets.
# Required: optional
# Defaults are tuned for v2.2 sink-keyed client reuse.
MONGODB_SINK_MAX_POOL_SIZE=20
MONGODB_SINK_MAX_CONNECTING=4
MONGODB_SINK_WAIT_QUEUE_TIMEOUT_MS=10000
MONGODB_SINK_IDLE_TTL_MS=60000
MONGODB_SINK_MAX_ACTIVE_CLIENTS=8
