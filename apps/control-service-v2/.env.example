# ======================================
# Service Bootstrap
# ======================================
# TCP port for Fastify server.
# Required: optional
# Default: 8080
PORT=8080

# Network bind host.
# Required: optional
# Default: 0.0.0.0
HOST=0.0.0.0

# Service name in logs and health endpoints.
# Required: optional
# Default: control-service-v2
SERVICE_NAME=control-service-v2

# Service version in logs and health endpoints.
# Required: optional
# Default: dev
SERVICE_VERSION=dev

# Pino log level.
# Required: optional
# Default: info
# Options: fatal, error, warn, info, debug, trace, silent
LOG_LEVEL=info

# Pretty-print logs in interactive local runs.
# Required: optional
# Default: false
# Options: true, false
LOG_PRETTY=true

# ======================================
# Control Plane Auth
# ======================================
# Shared bearer token for control-plane API auth.
# Required: yes
# Default: none
CONTROL_SHARED_TOKEN=replace-me

# ======================================
# Persistence (Control Plane DB)
# ======================================
# Control-service MongoDB connection URI.
# Required: yes
# Default: none
MONGODB_URI=mongodb://localhost:27017/omnicrawl

# MongoDB database name for control-plane state.
# Required: yes
# Default: none
CONTROL_PLANE_DB_NAME=omnicrawl-control-plane

# ======================================
# Worker Endpoints
# ======================================
# Base URL for crawler-worker-v2 (no trailing slash).
# Required: yes
# Default: none
CRAWLER_WORKER_BASE_URL=http://localhost:3010

# Base URL for ingestion-worker-v2 (no trailing slash).
# Required: yes
# Default: none
INGESTION_WORKER_BASE_URL=http://localhost:3020

# ======================================
# GCP and Pub/Sub
# ======================================
# GCP project for Pub/Sub and GCS integrations.
# Required: yes
# Default: none
GCP_PROJECT_ID=your-gcp-project

# Pub/Sub topic carrying runtime events.
# Required: yes
# Default: none
PUBSUB_EVENTS_TOPIC=run-events

# Pub/Sub subscription consumed by control-service.
# Required: yes
# Default: none
PUBSUB_EVENTS_SUBSCRIPTION=control-service-v2-events

# Auto-create subscription if it does not exist.
# Required: optional
# Default: true
PUBSUB_AUTO_CREATE_SUBSCRIPTION=true

# Enable Pub/Sub event consumer loop.
# Required: optional
# Default: true
ENABLE_PUBSUB_CONSUMER=true

# SSE heartbeat interval for stream clients.
# Required: optional
# Default: 15000
SSE_HEARTBEAT_INTERVAL_MS=15000

# ======================================
# Artifact Storage Routing
# ======================================
# Artifact sink policy owned by control-service.
# This routing is injected into crawler/ingestion StartRun payloads.

# Storage backend.
# Required: optional
# Default: gcs
# Options: local_filesystem, gcs
CONTROL_PLANE_ARTIFACT_STORAGE_BACKEND=gcs

# Local base path for artifacts.
# Required: conditional (when backend=local_filesystem)
# Default: control-plane-artifacts
CONTROL_PLANE_ARTIFACT_STORAGE_LOCAL_BASE_PATH=control-plane-artifacts

# GCS bucket for artifacts.
# Required: conditional (when backend=gcs)
# Default: none
CONTROL_PLANE_ARTIFACT_STORAGE_GCS_BUCKET=your-omnicrawl-artifacts-bucket

# GCS prefix for artifacts.
# Required: optional
# Default: empty string
CONTROL_PLANE_ARTIFACT_STORAGE_GCS_PREFIX=

# ======================================
# JSON Bundle Safeguards
# ======================================
# Max size of /download-all archive in bytes.
# Required: optional
# Default: 104857600
CONTROL_PLANE_JSON_BUNDLE_MAX_BYTES=104857600

# Max generation time of /download-all archive in ms.
# Required: optional
# Default: 120000
CONTROL_PLANE_JSON_BUNDLE_TIMEOUT_MS=120000

# Skip artifact sink connectivity preflight checks.
# Required: optional
# Default: false
CONTROL_PLANE_SKIP_SINK_PREFLIGHT=false
