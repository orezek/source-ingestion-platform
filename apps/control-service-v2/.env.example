PORT=8080
HOST=0.0.0.0
SERVICE_NAME=control-service-v2
SERVICE_VERSION=dev
LOG_LEVEL=info
LOG_PRETTY=true

CONTROL_SHARED_TOKEN=replace-me

MONGODB_URI=mongodb://localhost:27017/omnicrawl
CONTROL_PLANE_DB_NAME=omnicrawl-control-plane

CRAWLER_WORKER_BASE_URL=http://localhost:3010
INGESTION_WORKER_BASE_URL=http://localhost:3020

GCP_PROJECT_ID=your-gcp-project
PUBSUB_EVENTS_TOPIC=run-events
PUBSUB_EVENTS_SUBSCRIPTION=control-service-v2-events
PUBSUB_AUTO_CREATE_SUBSCRIPTION=true
ENABLE_PUBSUB_CONSUMER=true

SSE_HEARTBEAT_INTERVAL_MS=15000

# Artifact sink selection for crawler StartRun.
# For local development:
CONTROL_PLANE_ARTIFACT_STORAGE_BACKEND=local_filesystem
CONTROL_PLANE_ARTIFACT_STORAGE_LOCAL_BASE_PATH=control-plane-artifacts

# For GCP deployment set backend=gcs and configure the bucket.
CONTROL_PLANE_ARTIFACT_STORAGE_GCS_BUCKET=
CONTROL_PLANE_ARTIFACT_STORAGE_GCS_PREFIX=
