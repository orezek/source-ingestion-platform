# Runtime + infrastructure config only.
# Ingestion does not define crawl scope.
#
# Triggered runs receive:
# - crawlRunId
# - searchSpaceId
# - mongoDbName
# - listingRecord
# - detailHtmlPath
#
# Manual runs derive the target DB as:
#   <JOB_COMPASS_DB_PREFIX>-<SEARCH_SPACE_ID>

NODE_ENV=development
LOG_LEVEL=info
LOG_PRETTY=false
LOG_TEXT_TRANSFORM_CONTENT=false
LOG_TEXT_TRANSFORM_PREVIEW_CHARS=1200

# Local crawler artifact root for manual/bulk ingestion runs.
# Layout:
#   <INPUT_ROOT_DIR>/runs/<crawlRunId>/dataset.json
#   <INPUT_ROOT_DIR>/runs/<crawlRunId>/records/*.html
INPUT_ROOT_DIR=scrapped_jobs
INPUT_RECORDS_DIR_NAME=records
CRAWL_RUNS_SUBDIR=runs

# Positive integer, "all", or leave empty to process all records in manual/bulk mode.
INGESTION_SAMPLE_SIZE=3
INGESTION_CONCURRENCY=1

# Gemini / LangSmith
GEMINI_API_KEY=
LANGSMITH_API_KEY=
LLM_EXTRACTOR_PROMPT_NAME=jobcompass-job-ad-structured-extractor
LLM_CLEANER_PROMPT_NAME=jobcompass-job-ad-text-cleaner
GEMINI_MODEL=gemini-3-flash-preview
GEMINI_TEMPERATURE=0
GEMINI_THINKING_LEVEL=LOW
DETAIL_PAGE_MIN_RELEVANT_TEXT_CHARS=700
GEMINI_INPUT_PRICE_USD_PER_1M_TOKENS=0.50
GEMINI_OUTPUT_PRICE_USD_PER_1M_TOKENS=3.00

# Local debug output for manual/bulk runs
OUTPUT_JSON_PATH=output/normalized-jobs.json
INGESTION_API_HOST=127.0.0.1
INGESTION_API_PORT=3010
PARSER_VERSION=jobs-ingestion-service-v1.0.0

# Default DB derivation for manual runs:
#   <JOB_COMPASS_DB_PREFIX>-<SEARCH_SPACE_ID>
JOB_COMPASS_DB_PREFIX=job-compass
SEARCH_SPACE_ID=default

# Optional explicit DB override for this process.
# Prefer leaving this unset and letting the search space derive the DB automatically.
# MONGODB_DB_NAME=

# Mongo Atlas persistence
ENABLE_MONGO_WRITE=false
MONGODB_URI=
MONGODB_JOBS_COLLECTION=normalized_job_ads
MONGODB_RUN_SUMMARIES_COLLECTION=ingestion_run_summaries
MONGODB_INGESTION_TRIGGERS_COLLECTION=ingestion_trigger_requests
