# Planner backend: use `gemini` for the LLM-backed planner, `heuristic` for local deterministic testing.
JOB_COMPASS_CHAT_PLANNER_MODE=gemini

# Shared Gemini runtime settings.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-3-flash-preview
GEMINI_TEMPERATURE=0
GEMINI_THINKING_LEVEL=LOW

# Loop safety guard.
JOB_COMPASS_CHAT_MAX_STEPS=10
