{
  "actorSpecification": 1,
  "name": "jobs-crawler-actor",
  "version": "1.1",
  "title": "Jobs.cz Scraper",
  "description": "Scrapes job listings and details from Jobs.cz including salary, location, and company data.",
  "dockerfile": "../Dockerfile",
  "readme": "../README.md",
  "storages": {
    "dataset": {
      "actorSpecification": 1,
      "title": "Job Listings",
      "views": {
        "overview": {
          "title": "Overview",
          "transformation": {
            "fields": ["adUrl", "jobTitle", "companyName"]
          }
        }
      }
    }
  },
  "environmentVariables": {
    "CRAWLEE_LOG_LEVEL": "INFO"
  },
  "dockerContextDir": "../../../",
  "minMemoryMbytes": 1024
}
