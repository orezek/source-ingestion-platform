CRAWLEE_LOG_LEVEL=INFO

# Run profile convention (operator-managed, no runtime switch):
# - prod_full:   MONGODB_DB_NAME=jobCompass, ENABLE_INGESTION_TRIGGER=true, full INPUT.json maxItems
# - dev_sample:  MONGODB_DB_NAME=job-compass-dev, ENABLE_INGESTION_TRIGGER=false (optional), small INPUT.json maxItems

# MVP guard rails: enforce the fixed jobs.cz Praha + selected categories URL.
MVP_ENFORCE_FIXED_START_URL_SCOPE=true
MVP_FIXED_START_URL=https://www.jobs.cz/prace/praha/?field%5B%5D=200900012&field%5B%5D=200900013&field%5B%5D=200900011&field%5B%5D=200900033&locality%5Bradius%5D=0

# Protect production crawl-state DB from sample/partial runs (maxItems-limited list scans).
# For development runs, point MONGODB_DB_NAME to a separate DB, e.g. `job-compass-dev`.
ENFORCE_FULL_SCAN_FOR_PROD_CRAWL_STATE=true
PROD_CRAWL_STATE_DB_NAME=jobCompass

# Local MVP handoff directory shared with jobs-ingestion-service.
LOCAL_SHARED_SCRAPED_JOBS_DIR=../jobs-ingestion-service/scrapped_jobs

# Trigger jobs-ingestion-service after crawl finalization.
ENABLE_INGESTION_TRIGGER=false
INGESTION_TRIGGER_URL=http://127.0.0.1:3010/ingestion/start
INGESTION_TRIGGER_TIMEOUT_MS=10000

# Incremental crawl reconciliation (crawler state collection).
MONGODB_URI=
MONGODB_DB_NAME=jobCompass
MONGODB_CRAWL_JOBS_COLLECTION=crawl_job_states

# Guard rails for immediate inactive marking (MVP).
CRAWL_INACTIVE_GUARD_MIN_ACTIVE_COUNT=100
CRAWL_INACTIVE_GUARD_MIN_SEEN_RATIO=0.5

# Optional crawl run summary persistence.
ENABLE_MONGO_RUN_SUMMARY_WRITE=false
MONGODB_CRAWL_RUN_SUMMARIES_COLLECTION=crawl_run_summaries
