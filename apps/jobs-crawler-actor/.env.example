# Runtime + infrastructure config only.
# Crawl scope and behavior belong in:
#   apps/jobs-crawler-actor/search-spaces/*.json
#
# Local operator flow:
#   pnpm -C apps/jobs-crawler-actor build
#   pnpm -C apps/jobs-crawler-actor start -- --search-space prague-tech-jobs --max-items 100

# Crawlee logger level: DEBUG | INFO | WARNING | ERROR | OFF
CRAWLEE_LOG_LEVEL=INFO

# Canonical MongoDB database prefix.
# The crawler derives the target database as:
#   <JOB_COMPASS_DB_PREFIX>-<searchSpaceId>
# Example:
#   JOB_COMPASS_DB_PREFIX=omni-crawl
#   searchSpaceId=prague-tech-jobs
#   => omni-crawl-prague-tech-jobs
JOB_COMPASS_DB_PREFIX=omni-crawl

# Optional explicit DB override for this process.
# Prefer leaving this unset and letting the search-space derive the DB automatically.
# MONGODB_DB_NAME=

# Base directory where the crawler writes artifacts for ingestion.
# Layout:
#   runs/<crawlRunId>/dataset.json
#   runs/<crawlRunId>/records/job-html-<sourceId>.html
LOCAL_SHARED_SCRAPED_JOBS_DIR=../jobs-ingestion-service/scrapped_jobs

# If true, trigger one asynchronous ingestion request per persisted detail artifact.
ENABLE_INGESTION_TRIGGER=false
INGESTION_TRIGGER_URL=http://127.0.0.1:3010/ingestion/item
INGESTION_TRIGGER_TIMEOUT_MS=10000

# Mongo connection string.
# Required for phase-one reconciliation against normalized_job_ads and for run-summary writes.
MONGODB_URI=
MONGODB_JOBS_COLLECTION=normalized_job_ads
ENABLE_MONGO_RUN_SUMMARY_WRITE=false
MONGODB_CRAWL_RUN_SUMMARIES_COLLECTION=crawl_run_summaries

# Guard activates only when current active count is at least this value.
CRAWL_INACTIVE_GUARD_MIN_ACTIVE_COUNT=100
# If listings_seen / active_before is below this ratio, mass inactivation is skipped.
CRAWL_INACTIVE_GUARD_MIN_SEEN_RATIO=0.5
