# -----------------------------
# Logging
# -----------------------------
# Crawlee logger level: DEBUG | INFO | WARNING | ERROR | OFF
CRAWLEE_LOG_LEVEL=INFO

# -----------------------------
# MVP crawl scope guard
# -----------------------------
# If true, actor input startUrls must contain exactly one URL equal to MVP_FIXED_START_URL.
MVP_ENFORCE_FIXED_START_URL_SCOPE=true
# Fixed jobs.cz MVP URL (Praha + selected categories + 0 km radius).
MVP_FIXED_START_URL=https://www.jobs.cz/prace/praha/?field%5B%5D=200900012&field%5B%5D=200900013&field%5B%5D=200900011&field%5B%5D=200900033&locality%5Bradius%5D=0

# -----------------------------
# Production-state safety guard
# -----------------------------
# If true, partial list scans are blocked when writing into PROD_CRAWL_STATE_DB_NAME.
ENFORCE_FULL_SCAN_FOR_PROD_CRAWL_STATE=true
# DB name treated as production crawl-state database by the guard above.
PROD_CRAWL_STATE_DB_NAME=jobCompass

# -----------------------------
# Local crawler -> ingestion handoff
# -----------------------------
# Base directory where crawler writes runs/<crawlRunId>/dataset.json and records/*.html.
LOCAL_SHARED_SCRAPED_JOBS_DIR=../jobs-ingestion-service/scrapped_jobs

# -----------------------------
# Ingestion trigger (optional)
# -----------------------------
# If true, call jobs-ingestion-service POST /ingestion/start after crawl finalization.
ENABLE_INGESTION_TRIGGER=false
# Fastify ingestion endpoint URL.
INGESTION_TRIGGER_URL=http://127.0.0.1:3010/ingestion/start
# Timeout for ingestion trigger HTTP call in milliseconds.
INGESTION_TRIGGER_TIMEOUT_MS=10000

# -----------------------------
# MongoDB crawl state + reconciliation
# -----------------------------
# Mongo connection string (required for crawl-state reconcile).
MONGODB_URI=
# Mongo database used by this run (set to job-compass-dev for sample runs).
MONGODB_DB_NAME=jobCompass
# Crawl-state collection used for active/inactive + dedupe decisions.
MONGODB_CRAWL_JOBS_COLLECTION=crawl_job_states

# -----------------------------
# Inactive-marking safety thresholds
# -----------------------------
# Guard activates only when current active count is at least this value.
CRAWL_INACTIVE_GUARD_MIN_ACTIVE_COUNT=100
# If listings_seen / active_before is below this ratio, mass inactivation is skipped.
CRAWL_INACTIVE_GUARD_MIN_SEEN_RATIO=0.5

# -----------------------------
# Crawl run summary persistence
# -----------------------------
# If true, persist crawl run summary into Mongo.
ENABLE_MONGO_RUN_SUMMARY_WRITE=false
# Collection for crawler run summaries.
MONGODB_CRAWL_RUN_SUMMARIES_COLLECTION=crawl_run_summaries

# -----------------------------
# Input-driven runtime controls (not env vars)
# -----------------------------
# Set these in Actor input / INPUT.json:
# - maxItems
# - maxConcurrency
# - maxRequestsPerMinute
