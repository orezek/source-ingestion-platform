# Data mode for the dashboard.
# mongo   -> read live summary collections from MongoDB.
# fixture -> read JSON fixtures from DASHBOARD_FIXTURE_DIR (recommended for tests/local UI work).
DASHBOARD_DATA_MODE=mongo

# Database selection for the dashboard process.
# The dashboard reads exactly one database:
# - MONGODB_DB_NAME if set
# - otherwise JOB_COMPASS_DB_PREFIX
JOB_COMPASS_DB_PREFIX=omni-crawl

# Mongo connection used when DASHBOARD_DATA_MODE=mongo.
MONGODB_URI=
# Runtime DB override for this process.
# Set this when you want the dashboard to target a search-space-specific DB,
# for example:
#   omni-crawl-prague-tech-jobs
# MONGODB_DB_NAME=
MONGODB_CRAWL_RUN_SUMMARIES_COLLECTION=crawl_run_summaries
MONGODB_INGESTION_RUN_SUMMARIES_COLLECTION=ingestion_run_summaries
MONGODB_INGESTION_TRIGGER_REQUESTS_COLLECTION=ingestion_trigger_requests

# Default overview time window.
# Allowed: 24h, 7d, 30d
DASHBOARD_DEFAULT_TIME_RANGE=7d

# Fixture directory used when DASHBOARD_DATA_MODE=fixture.
DASHBOARD_FIXTURE_DIR=./src/test/fixtures

# Local v1 control-plane storage and execution.
# fixture     -> simulate crawler/ingestion runs for UI and automated tests.
# local_cli   -> spawn the legacy local crawler and ingestion worker adapters.
# worker_http -> call standalone V2 crawler/ingestion workers over HTTP.
CONTROL_PLANE_EXECUTION_MODE=fixture

# Ingestion parser backend used only for local_cli worker launches.
# gemini  -> current production-like LangSmith + Gemini parsing path
# fixture -> deterministic local parser for smoke tests and local validation
CONTROL_PLANE_INGESTION_PARSER_BACKEND=gemini

# Broker transport used by worker-to-worker runtime events.
# local      -> archive-only local file broker
# gcp_pubsub -> publish to Google Cloud Pub/Sub and archive locally for operator visibility
CONTROL_PLANE_BROKER_BACKEND=local
CONTROL_PLANE_GCP_PROJECT_ID=
CONTROL_PLANE_GCP_PUBSUB_TOPIC=omnicrawl-control-plane-events
CONTROL_PLANE_GCP_PUBSUB_SUBSCRIPTION_PREFIX=omnicrawl-control-plane-run

# Standalone V2 worker endpoints used only when CONTROL_PLANE_EXECUTION_MODE=worker_http.
# Use the same shared bearer token configured on the workers.
CONTROL_PLANE_CRAWLER_WORKER_BASE_URL=
CONTROL_PLANE_INGESTION_WORKER_BASE_URL=
CONTROL_PLANE_WORKER_AUTH_TOKEN=
CONTROL_PLANE_WORKER_HTTP_TIMEOUT_MS=10000

# File-backed control-plane state and broker paths.
CONTROL_PLANE_DATA_DIR=./storage/control-plane
CONTROL_PLANE_BROKER_DIR=./storage/control-plane/broker
CONTROL_PLANE_WORKER_LOG_DIR=./storage/control-plane/logs

# Search spaces bootstrapped into the control plane on first run.
CONTROL_PLANE_BOOTSTRAP_SEARCH_SPACES_DIR=../jobs-crawler-actor/search-spaces

# Local managed storage roots used when the managed backend is local_filesystem.
CONTROL_PLANE_DEFAULT_ARTIFACT_DIR=../jobs-ingestion-service/scrapped_jobs
CONTROL_PLANE_DEFAULT_JSON_OUTPUT_DIR=../jobs-ingestion-service/output/control-plane

# Managed artifact storage backend used by the control plane.
# local_filesystem -> operators browse/download via the dashboard, backed by CONTROL_PLANE_DEFAULT_ARTIFACT_DIR
# gcs              -> operators browse/download via the dashboard, backed by the configured bucket/prefix
CONTROL_PLANE_ARTIFACT_STORAGE_BACKEND=local_filesystem
CONTROL_PLANE_ARTIFACT_STORAGE_GCS_BUCKET=
CONTROL_PLANE_ARTIFACT_STORAGE_GCS_PREFIX=

# Managed downloadable JSON backend used for the downloadable_json structured output type.
CONTROL_PLANE_DOWNLOADABLE_OUTPUT_BACKEND=local_filesystem
CONTROL_PLANE_DOWNLOADABLE_OUTPUT_GCS_BUCKET=
CONTROL_PLANE_DOWNLOADABLE_OUTPUT_GCS_PREFIX=

# Google credentials are resolved through standard ADC env/config when GCS or Pub/Sub adapters are used:
#   GOOGLE_APPLICATION_CREDENTIALS=/abs/path/to/service-account.json
#   or gcloud application-default login

# Worker launcher command used in local_cli mode.
CONTROL_PLANE_PNPM_BIN=pnpm
