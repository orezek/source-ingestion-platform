NODE_ENV=development
LOG_LEVEL=info
LOG_PRETTY=false
INPUT_ROOT_DIR=scrapped_jobs
INPUT_RECORDS_DIR_NAME=records
# positive integer, "all", or leave empty to process all records
INGESTION_SAMPLE_SIZE=3
INGESTION_CONCURRENCY=1

# Gemini setup (set your own key)
GEMINI_API_KEY=
LANGSMITH_API_KEY=
LANGSMITH_PROMPT_NAME=job-ad-extractor
GEMINI_MODEL=gemini-3-flash-preview
GEMINI_TEMPERATURE=0
GEMINI_THINKING_LEVEL=LOW
DETAIL_PAGE_MIN_RELEVANT_TEXT_CHARS=700
GEMINI_INPUT_PRICE_USD_PER_1M_TOKENS=0.50
GEMINI_OUTPUT_PRICE_USD_PER_1M_TOKENS=3.00

# Local debug output
OUTPUT_JSON_PATH=output/normalized-jobs.json
CRAWL_RUNS_SUBDIR=runs
INGESTION_API_HOST=127.0.0.1
INGESTION_API_PORT=3010
PARSER_VERSION=job-ingestion-service-v0.5.0

# Mongo Atlas persistence (disabled by default)
ENABLE_MONGO_WRITE=false
MONGODB_URI=
MONGODB_DB_NAME=jobcompass
MONGODB_JOBS_COLLECTION=ingestionCollection
MONGODB_RUN_SUMMARIES_COLLECTION=ingestionRunSummaryCollection
MONGODB_INGESTION_TRIGGERS_COLLECTION=ingestionTriggerCollection
