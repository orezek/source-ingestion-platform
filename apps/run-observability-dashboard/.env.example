# Data mode for the dashboard.
# mongo   -> read live summary collections from MongoDB.
# fixture -> read JSON fixtures from DASHBOARD_FIXTURE_DIR (recommended for tests/local UI work).
DASHBOARD_DATA_MODE=mongo

# Database selection for the dashboard process.
# The dashboard reads exactly one database:
# - MONGODB_DB_NAME if set
# - otherwise JOB_COMPASS_DB_PREFIX
JOB_COMPASS_DB_PREFIX=job-compass

# Mongo connection used when DASHBOARD_DATA_MODE=mongo.
MONGODB_URI=
# Runtime DB override for this process.
# Set this when you want the dashboard to target a search-space-specific DB,
# for example:
#   job-compass-prague-tech-jobs
# MONGODB_DB_NAME=
MONGODB_CRAWL_RUN_SUMMARIES_COLLECTION=crawl_run_summaries
MONGODB_INGESTION_RUN_SUMMARIES_COLLECTION=ingestion_run_summaries
MONGODB_INGESTION_TRIGGER_REQUESTS_COLLECTION=ingestion_trigger_requests

# Default overview time window.
# Allowed: 24h, 7d, 30d
DASHBOARD_DEFAULT_TIME_RANGE=7d

# Fixture directory used when DASHBOARD_DATA_MODE=fixture.
DASHBOARD_FIXTURE_DIR=./src/test/fixtures
